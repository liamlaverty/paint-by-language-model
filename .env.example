# VLM Provider ("mistral", "lmstudio", or "anthropic")
PROVIDER=mistral

# Mistral API key (required when PROVIDER=mistral)
# Get your key at https://admin.mistral.ai/
MISTRAL_API_KEY=your_api_key_here

# Anthropic API key (required when PROVIDER=anthropic)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Enable Anthropic prompt caching to reduce API costs (default: true)
# Set to false to disable for debugging or cost comparison
ANTHROPIC_PROMPT_CACHING=true
